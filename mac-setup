#!/bin/sh

set -eu

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

readonly REPO_NAME="mac-config"
readonly REPO_URL="https://github.com/pervezfunctor/${REPO_NAME}.git"
readonly DOT_DIR="$HOME/.${REPO_NAME}"

GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

log() { printf "${GREEN}✔${RESET} %s\n" "$*"; }
warn() { printf "${YELLOW}${BOLD}⚠${RESET} %s\n" "$*" >&2; }
die() {
  printf "${RED}${BOLD}✖${RESET} %s\n" "$*" >&2
  exit 1
}

dotfiles_install() {
  has_cmd git || die "git not found. Quitting."

  if [ ! -d "$DOT_DIR" ]; then
    log "Cloning dotfiles to $DOT_DIR."
    git clone "$REPO_URL" "$DOT_DIR" || die "Failed to clone $REPO_URL"
  elif [ -z "$(git -C "$DOT_DIR" status --porcelain)" ]; then
    log "Dotfiles repo clean. Pulling latest changes..."
    if ! git -C "$DOT_DIR" pull --rebase; then
      log "Rebase failed. Aborting."
      git -C "$DOT_DIR" rebase --abort || die "Failed to abort rebase."
    fi
  else
    log "Dotfiles repo dirty. Skipping update"
  fi
}

system_install() {
  if ! xcode-select -p >/dev/null 2>&1; then
    log "Installing Xcode Command Line Tools. Re-run the script after installation finishes."
    xcode-select --install
    exit 0
  fi
  if [ "$(uname -m)" = "arm64" ] && ! pkgutil --pkg-info com.apple.pkg.RosettaUpdateAuto >/dev/null 2>&1; then
    /usr/sbin/softwareupdate --install-rosetta --agree-to-license
  fi
}

brew_install() {
  has_cmd brew && return
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

brew_packages_install() {
  has_cmd brew || die "brew not found. Quitting."
  brew install -q fish nushell trash-cli starship fzf zoxide bat direnv \
    eza fd gh jq xh ripgrep tealdeer make unzip

  tldr --update || true
}

set_fish_as_default_shell() {
  has_cmd fish || die "fish not found. Quitting."

  fish_path="$(command -v fish)"

  if [ "$SHELL" = "$fish_path" ]; then
    log "fish is already the default shell."
    return
  fi

  if ! grep -qxF "$fish_path" /etc/shells 2>/dev/null; then
    warn "Adding $fish_path to /etc/shells."
    if ! printf '%s\n' "$fish_path" | sudo tee -a /etc/shells >/dev/null; then
      warn "Failed to add $fish_path to /etc/shells."
      return
    fi
  else
    log "$fish_path is already in /etc/shells."
  fi

  if chsh -s "$fish_path"; then
    log "Default shell set to fish ($fish_path). Re-login to apply."
  else
    warn "Failed to set fish as default shell. Try running 'chsh -s $fish_path' manually."
  fi
}

fish_config() {
  has_cmd fish || die "fish not installed. Quitting."
  if [ -L ~/.config/fish/config.fish ] &&
    [ "$(readlink ~/.config/fish/config.fish)" = "${DOT_DIR}/fish/config.fish" ]; then
    return
  fi

  mkdir -p ~/.config/fish
  if [ -f ~/.config/fish/config.fish ]; then
    log "Trashing existing fish config..."
    trash ~/.config/fish/config.fish
  fi
  ln -sf "${DOT_DIR}/fish/config.fish" ~/.config/fish/config.fish

  set_fish_as_default_shell
}

fresh_install() {
  system_install
  dotfiles_install
  brew_install
  brew_packages_install
  fish_config
  has_cmd nu || die "nu not installed. Quitting."
}

has_commands() {
  for cmd in "$@"; do
    has_cmd "$cmd" || return 1
  done
}

main() {
  export PATH="/opt/homebrew/bin:$PATH"

  [ "$(uname)" = "Darwin" ] || die "Not a Mac. Quitting."

  if has_commands git fish nu trash starship gum brew; then
    log "All commands found, skipping fresh install. Use '${DOT_DIR}/scripts/setup.nu' to configure your system"
  else
    fresh_install
  fi
}

main "$@"
