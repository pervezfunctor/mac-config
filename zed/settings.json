{
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "neocmake": true,
    "make": true,
  },
  "cli_default_open_behavior": "new_window",
  "icon_theme": "Catppuccin Mocha",
  "ui_font_size": 16,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Frappé",
    "dark": "Catppuccin Mocha",
  },
}
